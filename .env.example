# --- FIREBASE PUBLIC CONFIG (Client Side) ---
# From Firebase console → Project settings → Your apps → </>
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id"

# --- GOOGLE ONE TAP (Optional) ---
# Web OAuth Client ID from Google Cloud Console → APIs & Services → Credentials.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# --- WEB PUSH (Optional — for PWA push notifications via VAPID) ---
# Generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_FIREBASE_VAPID_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"

# --- FIREBASE EMULATORS (Local Development) ---
# Setting NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true makes the client SDK connect to
# the emulator suite. The non-prefixed vars are read by the Admin SDK.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR="true"
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST="localhost:8080"
NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST="localhost:9199"
FIRESTORE_EMULATOR_HOST="localhost:8080"
FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"
FIREBASE_STORAGE_EMULATOR_HOST="localhost:9199"

# --- FIREBASE ADMIN SDK (Server Side) ---
# Required for API routes in production. Paste the full service-account JSON
# on one line. Leave unset in local dev — the Admin SDK auto-targets the emulator.
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# --- APPLICATION SETTINGS ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- UPSTASH REDIS (Optional — rate limiting) ---
# Without these, the app falls back to in-memory rate limiting (fine for local dev,
# wrong for serverless at scale). Create a free DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# --- SENTRY (Optional — error monitoring) ---
NEXT_PUBLIC_SENTRY_DSN="https://your-key@your-org.ingest.sentry.io/your-project-id"
# Auth token only needed on the Vercel production build (source-map upload).
SENTRY_AUTH_TOKEN="sntrys_..."
