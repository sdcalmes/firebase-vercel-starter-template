# Cloud Functions env — copy to functions/.env and fill in.
# Cloud Functions do NOT inherit Vercel or .env.local values; they read this file
# at deploy time (bundled into the function) and via firebase functions:secrets:set.

# Only needed if functions send Web Push notifications.
NEXT_PUBLIC_FIREBASE_VAPID_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"
